{
	"title": "Mon Dashboard",
	"uid": "mon-dashboard",
	"tags": [],
	"timezone": "browser",
	"schemaVersion": 16,
	"version": 0,
	"refresh": "5s",
	"panels": [
		{
			"id": 1,
			"title": "Usage CPU par service",
			"type": "timeseries",
			"gridPos": {
				"x": 0,
				"y": 0,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "rate(process_cpu_seconds_total{job=~\"auth|user|content|social|realtime|bff\"}[1m]) * 100",
					"legendFormat": "{{job}} - CPU %",
					"refId": "A"
				}
			],
			"options": {},
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100
				},
				"overrides": []
			}
		},
		{
			"id": 2,
			"title": "Mémoire utilisée par service",
			"type": "timeseries",
			"gridPos": {
				"x": 12,
				"y": 0,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "process_resident_memory_bytes{job=~\"auth|user|content|social|realtime|bff\"} / 1024 / 1024",
      				"legendFormat": "{{job}} - RAM (MB)",
      				"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "decmbytes",
					"min": 0
				}
			}
		},
		{
			"id": 3,
			"title": "Débit réseau global de l'infrastructure",
			"type": "timeseries",
			"gridPos": {
				"x": 0,
				"y": 8,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "rate(container_network_transmit_bytes_total{id=\"/\",interface=\"eno2\"}[1m])",
					"legendFormat": "Trafic sortant (TX)",
      				"refId": "A"
				},
				{
					"expr": "rate(container_network_receive_bytes_total{id=\"/\",interface=\"eno2\"}[1m])",
					"legendFormat": "Trafic entrant (RX)",
      				"refId": "B"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "Bps",
					"min": 0
				},
				"overrides": []
			}
		}
	],
	"time": {
		"from": "now-1h",
		"to": "now"
	}
}