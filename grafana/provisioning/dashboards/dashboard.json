{
	"title": "42Hub",
	"uid": "42Hub-dashboard",
	"tags": [],
	"timezone": "browser",
	"schemaVersion": 16,
	"version": 0,
	"refresh": "5s",
	"panels": [
		{
			"id": 1,
			"title": "Usage CPU par service",
			"type": "timeseries",
			"gridPos": {
				"x": 0,
				"y": 0,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
				"expr": "rate(container_cpu_usage_seconds_total{name=~\"auth|user|content|social|realtime|bff\"}[1m]) * 100",
				"legendFormat": "{{name}} - CPU %",
					"refId": "A"
				}
			],
			"options": {},
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100
				},
				"overrides": []
			}
		},
		{
			"id": 2,
			"title": "Mémoire utilisée par service",
			"type": "timeseries",
			"gridPos": {
				"x": 12,
				"y": 0,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "container_memory_usage_bytes{name=~\"auth|user|content|social|realtime|bff\"} / 1024 / 1024",
      				"legendFormat": "{{name}} - RAM (MB)",
      				"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "decmbytes",
					"min": 0
				}
			}
		},
		{
			"id": 3,
			"title": "Débit réseau par service",
			"type": "timeseries",
			"gridPos": {
				"x": 0,
				"y": 8,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\"auth|user|content|social|realtime|bff\"}[1m]))",
					"legendFormat": "{{name}} - TX",
      				"refId": "A"
				},
				{
					"expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"auth|user|content|social|realtime|bff\"}[1m]))",
					"legendFormat": "{{name}} - RX",
      				"refId": "B"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "Bps",
					"min": 0
				},
				"overrides": []
			}
		},
		{
			"id": 4,
			"title": "Nombre de requête par services",
			"type": "timeseries",
			"gridPos": {
				"x": 12,
				"y": 8,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"expr": "sum by (job) (rate(https_requests_total[1m]))",
					"legendFormat": "{{job}} req/s",
      				"refId": "A"
				}
			]
		},
		{
			"id": 5,
			"title": "Statut des règles d'alerte",
			"type": "alertlist",
			"gridPos": {
				"x": 0,
				"y": 16,
				"w": 12,
				"h": 8
			},
			"targets": [
				{
					"datasource": {
						"type": "prometheus",
						"uid": "prometheus"
					},
					"expr": "ALERTS",
					"refId": "A"
				}
			],
			"options": {
				"viewmode": "list",
				"groupMode": "default",
				"maxItems": 6,
				"sortOrder": 1,
				"stateFilter": {
					"firing": true,
					"pending": true,
					"noData": false,
					"normal": false
				}
			}

		}
	],
	"time": {
		"from": "now-1h",
		"to": "now"
	}
}